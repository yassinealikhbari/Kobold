{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev:vite -- --host 127.0.0.1",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/ingest?source=lifecycle",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
