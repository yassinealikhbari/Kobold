{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/ingest?source=all",
      "schedule": "23 7 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*|src/.*|@vite/.*|@id/.*|@fs/.*|node_modules/.*|assets/.*).*)",
      "destination": "/index.html"
    }
  ]
}
